{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hospital-emr-etl-prototype-2.onrender.com/:path*"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_BASE_URL": "/api"
  },
  "regions": ["sfo1"],
  "functions": {
    "api/**": {
      "maxDuration": 60
    }
  }
}
